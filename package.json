{
  "name": "agenticon",
  "version": "2.0.0",
  "description": "Deterministic geometric identicons — crisp SVG for the web and ANSI block-glyph art for the terminal, from one shared generator.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "agenticon": "bin/agenticon.js"
  },
  "files": [
    "src",
    "bin",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "gallery": "node bin/agenticon.js --gallery",
    "analyze": "node scripts/analyze.mjs"
  },
  "keywords": [
    "identicon",
    "avatar",
    "svg",
    "terminal",
    "ansi",
    "deterministic",
    "generative"
  ],
  "license": "MIT"
}
